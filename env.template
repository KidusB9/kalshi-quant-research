# Kalshi API Configuration
# Get your API key from: https://trading.kalshi.com/settings/api
KALSHI_API_KEY=your_kalshi_api_key_here

# Gemini API (RECOMMENDED — free, fast, no credits to manage)
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API (fallback — only used if GEMINI_API_KEY is not set)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Trading Configuration
# Set to 'true' for live trading, 'false' for paper trading
LIVE_TRADING_ENABLED=false

# MASTER KILL SWITCH (fail-safe). When 'true', the bot refuses to OPEN any new
# position (any buy) at the lowest API chokepoint, regardless of how it is
# launched. Selling/closing existing positions is still allowed. Defaults to
# halted if unset. Set to 'false' only when you deliberately resume trading.
TRADING_HALTED=true

# Logging Configuration
LOG_LEVEL=INFO
ENABLE_FILE_LOGGING=true
ENABLE_CONSOLE_LOGGING=true

# Database Configuration
DATABASE_URL=sqlite:///trading_system.db

# Performance Monitoring
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_LOG_INTERVAL_MINUTES=15
